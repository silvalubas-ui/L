# Copie para .env e ajuste. O docker-compose lê estas variáveis automaticamente.

# --------------------------------------------------------------------------- #
# Provedor de IA. Deixe vazio para detecção automática
# (anthropic se houver ANTHROPIC_API_KEY; senão ollama).
#   ollama | gemini | openai | anthropic
# --------------------------------------------------------------------------- #
LLM_PROVIDER=ollama

# --- Ollama (local, grátis — desenvolvimento) ------------------------------- #
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:3b

# --- Gemini (Google, endpoint compatível com OpenAI) ------------------------ #
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

# --- Anthropic / Claude ----------------------------------------------------- #
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- OpenAI (ou qualquer endpoint compatível) ------------------------------- #
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Fuso da clínica
LURI_TZ=America/Sao_Paulo
