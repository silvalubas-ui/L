# Copie para .env e ajuste. O docker-compose lê estas variáveis automaticamente.

# Chave da API da Anthropic. Sem ela, o app roda em "modo demonstração" (fallback sem IA).
ANTHROPIC_API_KEY=

# Modelo Claude usado pelo agente (padrão: claude-opus-4-8)
ANTHROPIC_MODEL=claude-opus-4-8

# Fuso da clínica
LURI_TZ=America/Sao_Paulo
